{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ESNext"],
    "types": ["vite/client"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,

    "baseUrl": "./resources",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["resources/ts/**/*.ts", "resources/ts/**/*.vue"]
}
