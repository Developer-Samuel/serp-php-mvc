{
  "name": "developer-samuel/inizio-search-results",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "support/functions/view.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "php-stan": [
      "Composer\\Config::disableProcessTimeout",
      "phpstan analyse --memory-limit=1G"
    ],
    "rector:fix": [
      "Composer\\Config::disableProcessTimeout",
      "rector process"
    ],
    "phpunit": [
      "Composer\\Config::disableProcessTimeout",
      "php bin/phpunit --testdox"
    ],
    "eslint": [
      "Composer\\Config::disableProcessTimeout",
      "npm run lint"
    ],
    "eslint:fix": [
      "Composer\\Config::disableProcessTimeout",
      "npm run lint:fix"
    ],
    "format:fix": [
      "Composer\\Config::disableProcessTimeout",
      "npx prettier --write ."
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npm run dev"
    ],
    "build": [
      "Composer\\Config::disableProcessTimeout",
      "npm run build"
    ],
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8000 -t public"
    ]
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.3",
    "phpunit/phpunit": "11"
  },
  "require": {
    "monolog/monolog": "^3.10"
  }
}
